MQTT_HOST=homeassistant.local
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=nova-shot-logger

NOVA_CONTEXT_TOPIC=golf/context/current
NOVA_SHOT_TOPIC=golf/shot/raw
NOVA_DISCARD_TOPIC=golf/context/discard_last_shot
NOVA_SUMMARY_PREFIX=golf/summary
NOVA_LOGGER_DB=data/nova-shots.sqlite3
NOVA_STORE_UNRECORDED=false
LOG_LEVEL=INFO
