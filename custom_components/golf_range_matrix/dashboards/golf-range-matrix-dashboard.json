{
  "title": "Golf Range Matrix",
  "resources": [
    {
      "url": "/golf_range_matrix/golf-range-matrix-cards.js",
      "type": "module"
    },
    {
      "url": "/hacsfiles/html-template-card/html-template-card.js",
      "type": "module"
    }
  ],
  "views": [
    {
      "title": "Launch Monitor",
      "path": "launch-monitor",
      "icon": "mdi:golf",
      "type": "sections",
      "max_columns": 3,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-shot-tracer-card"
            },
            {
              "type": "custom:range-metric-panel-card",
              "title": "Live Numbers"
            },
            {
              "type": "custom:range-shot-history-card"
            }
          ]
        }
      ],
      "cards": []
    },
    {
      "title": "Practice",
      "path": "practice",
      "icon": "mdi:target",
      "type": "sections",
      "max_columns": 3,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-session-control-card"
            },
            {
              "type": "horizontal-stack",
              "cards": [
                {
                  "type": "entity",
                  "entity": "switch.golf_range_matrix_range_matrix_recording",
                  "name": "Recording",
                  "icon": "mdi:record-rec",
                  "state_color": true,
                  "tap_action": {
                    "action": "toggle"
                  }
                },
                {
                  "type": "entity",
                  "entity": "switch.swing_analyzer",
                  "name": "Swing Analyzer",
                  "icon": "mdi:video-vintage",
                  "state_color": true,
                  "tap_action": {
                    "action": "toggle"
                  }
                }
              ]
            },
            {
              "type": "entities",
              "title": "Native Range Matrix Controls",
              "entities": [
                "select.range_matrix_active_player",
                "select.range_matrix_active_club",
                "switch.range_matrix_recording",
                "number.range_matrix_shots_per_club",
                "sensor.range_matrix_workflow"
              ]
            },
            {
              "type": "custom:range-wedge-matrix-card"
            },
            {
              "type": "custom:range-bag-builder-card"
            }
          ]
        }
      ],
      "cards": []
    },
    {
      "title": "Results",
      "path": "results",
      "icon": "mdi:clipboard-text-search",
      "type": "sections",
      "max_columns": 2,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-club-results-card"
            }
          ]
        }
      ],
      "cards": []
    },
    {
      "title": "Swing Analyzer",
      "path": "swing-analyzer",
      "icon": "mdi:video-vintage",
      "type": "sections",
      "max_columns": 2,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "vertical-stack",
              "cards": [
                {
                  "type": "markdown",
                  "content": "### Last swing\nPlays automatically when a new swing is analyzed."
                },
                {
                  "type": "custom:html-template-card",
                  "ignore_line_breaks": true,
                  "content": "{% set url = states('sensor.last_swing_annotated_url') %}\n{% set ts  = states('sensor.last_swing_timestamp') %}\n{% if url not in ['unknown','unavailable',''] %}\n  <video src=\"{{ url }}?t={{ ts }}\"\n         autoplay muted controls playsinline\n         style=\"width:100%; aspect-ratio:16/9; background:#000;\">\n    Your browser does not support HTML5 video.\n  </video>\n{% else %}\n  <div style=\"padding:1rem; color:#999; text-align:center;\">\n    No swing analyzed yet.\n  </div>\n{% endif %}"
                }
              ]
            },
            {
              "type": "entities",
              "title": "Latest Swing",
              "entities": [
                "switch.swing_analyzer",
                "sensor.last_swing_player",
                "sensor.last_swing_club",
                "sensor.last_swing_body_summary",
                "sensor.last_swing_faults",
                "sensor.last_swing_summary",
                "sensor.last_swing_annotated_url",
                "sensor.last_swing_raw_url",
                "sensor.last_swing_timestamp"
              ]
            }
          ]
        }
      ],
      "cards": []
    }
  ]
}
