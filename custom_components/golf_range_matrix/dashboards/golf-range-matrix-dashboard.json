{
  "title": "Golf Range Matrix",
  "resources": [
    {
      "url": "/golf_range_matrix/golf-range-matrix-cards.js",
      "type": "module"
    }
  ],
  "views": [
    {
      "title": "Launch Monitor",
      "path": "launch-monitor",
      "icon": "mdi:golf",
      "type": "sections",
      "max_columns": 3,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-shot-tracer-card"
            },
            {
              "type": "custom:range-metric-panel-card",
              "title": "Live Numbers"
            },
            {
              "type": "custom:range-shot-history-card"
            },
            {
              "type": "custom:range-swing-video-card",
              "title": "Last Swing",
              "grid_options": {
                "columns": "full",
                "rows": 10
              }
            }
          ]
        }
      ],
      "cards": []
    },
    {
      "title": "Practice",
      "path": "practice",
      "icon": "mdi:target",
      "type": "sections",
      "max_columns": 3,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-session-control-card"
            },
            {
              "type": "horizontal-stack",
              "cards": [
                {
                  "type": "entity",
                  "entity": "switch.golf_range_matrix_range_matrix_recording",
                  "name": "Recording",
                  "icon": "mdi:record-rec",
                  "state_color": true,
                  "tap_action": {
                    "action": "toggle"
                  }
                },
                {
                  "type": "entity",
                  "entity": "switch.golf_swing_analyzer_swing_analyzer",
                  "name": "Swing Analyzer",
                  "icon": "mdi:video-vintage",
                  "state_color": true,
                  "tap_action": {
                    "action": "toggle"
                  }
                }
              ]
            },
            {
              "type": "entities",
              "title": "Native Range Matrix Controls",
              "entities": [
                "select.range_matrix_active_player",
                "select.range_matrix_active_club",
                "switch.range_matrix_recording",
                "number.range_matrix_shots_per_club",
                "sensor.range_matrix_workflow"
              ]
            },
            {
              "type": "custom:range-wedge-matrix-card"
            },
            {
              "type": "custom:range-bag-builder-card"
            }
          ]
        }
      ],
      "cards": []
    },
    {
      "title": "Results",
      "path": "results",
      "icon": "mdi:clipboard-text-search",
      "type": "sections",
      "max_columns": 2,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-club-results-card"
            }
          ]
        }
      ],
      "cards": []
    },
    {
      "title": "Swing Analyzer",
      "path": "swing-analyzer",
      "icon": "mdi:video-vintage",
      "type": "sections",
      "max_columns": 2,
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "custom:range-swing-video-card",
              "title": "Last Swing",
              "grid_options": {
                "columns": "full",
                "rows": 10
              }
            },
            {
              "type": "entities",
              "title": "Latest Swing",
              "entities": [
                "switch.golf_swing_analyzer_swing_analyzer",
                "sensor.golf_swing_analyzer_last_swing_player",
                "sensor.golf_swing_analyzer_last_swing_club",
                "sensor.golf_swing_analyzer_last_swing_body_summary",
                "sensor.golf_swing_analyzer_last_swing_faults",
                "sensor.golf_swing_analyzer_last_swing_summary",
                "sensor.golf_swing_analyzer_last_swing_annotated_url",
                "sensor.golf_swing_analyzer_last_swing_raw_url",
                "sensor.golf_swing_analyzer_last_swing_timestamp"
              ]
            },
            {
              "type": "entities",
              "title": "SIM Control",
              "entities": [
                "button.golf_sim_control_restart_obs_bridge",
                "button.golf_sim_control_start_obs",
                "button.golf_sim_control_select_swing_analyzer_scene",
                "button.golf_sim_control_start_replay_buffer",
                "button.golf_sim_control_save_replay_buffer",
                "button.golf_sim_control_restart_swing_analyzer",
                "sensor.golf_sim_control_status",
                "sensor.golf_sim_control_last_result",
                "sensor.golf_sim_control_obs_running",
                "sensor.golf_sim_control_obs_scene",
                "sensor.golf_sim_control_scene_matches"
              ]
            }
          ]
        }
      ],
      "cards": []
    }
  ]
}
